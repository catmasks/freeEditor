{
  "name": "free-editor",
  "private": true,
  "engines": {
    "pnpm": ">=10.26.2"
  },
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter @catmasks/free-editor build",
    "pack:check": "pnpm --filter @catmasks/free-editor check-package",
    "publish:check": "pnpm build && pnpm pack:check"
  }
}
