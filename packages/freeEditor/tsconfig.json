{
  "compilerOptions": {
    "target": "ESNext",

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,

    "declarationMap": false,

    "sourceMap": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "isolatedModules": true,

    "lib": ["ESNext", "DOM"]
  },

  "include": ["src"]
}
