{
  "name": "@catmasks/free-editor",
  "version": "0.0.4",
  "type": "module",
  "description": "A lightweight open-source rich text editor based on TipTap",
  "author": "catmasks",
  "keywords": [
    "editor",
    "tiptap",
    "rich-text",
    "catmasks",
    "vue-editor"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.min.js",
  "jsdelivr": "./dist/index.min.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "copy-readme": "node scripts/copy-readme.mjs",
    "check-package": "node scripts/check-package.mjs",
    "build": "pnpm run copy-readme && vite build && pnpm run check-package",
    "prepack": "pnpm run copy-readme"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/catmasks/freeEditor.git"
  },
  "homepage": "https://github.com/catmasks/freeEditor#readme",
  "license": "Apache",
  "bugs": {
    "url": "https://github.com/catmasks/freeEditor/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css",
      "default": "./dist/style.css"
    }
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "peerDependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-gapcursor": "^3.26.1",
    "@tiptap/pm": "^3.26.1"
  },
  "devDependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-gapcursor": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@types/node": "^24.12.3",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-bundle-dts": "^0.5.0"
  }
}
